# Copie para .env e preencha. Nunca commite o arquivo .env.

# Firebase (servidas ao browser apenas por /api/firebase-config)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_DATABASE_URL=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Gemini — apenas nas Functions da Vercel (api/analyze-pdf.js)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
